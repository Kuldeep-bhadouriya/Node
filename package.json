{
  "name": "node",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/node": "^26.0.1",
      "next": "^16.2.9",
      "@prisma/client": "^7.8.0",
      "@trpc/server": "^11.18.0",
      "@trpc/client": "^11.18.0",
      "better-auth": "^1.6.22",
      "vitest": "4.1.8",
      "@vitest/ui": "4.1.8",
      "@vitest/coverage-v8": "4.1.8",
      "jsdom": "^29.1.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @node/db db:push",
    "db:studio": "turbo -F @node/db db:studio",
    "db:generate": "turbo -F @node/db db:generate",
    "db:migrate": "turbo -F @node/db db:migrate",
    "db:seed": "turbo -F @node/db db:seed",
    "test": "bun run --filter web test && bun run --filter @node/api test",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@node/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@node/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "kysely": "0.28.17"
  },
  "packageManager": "bun@1.3.14"
}
