{
  "name": "@node/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit --declaration false --declarationMap false --composite false",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "bun --env-file=../../apps/web/.env prisma/seed.ts"
  },
  "dependencies": {
    "@node/env": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "catalog:",
    "dotenv": "catalog:",
    "pg": "^8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@node/config": "workspace:*",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}
